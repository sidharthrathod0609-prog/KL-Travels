# Supabase Project Credentials (required)
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-public-key"

# Cloudflare Turnstile Bot Protection (required for forms submission)
# For local testing, you can use the dummy testing key: "1x00000000000000000000AA"
# For production, register your domain on Cloudflare and generate a Turnstile Site Key
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY="your-turnstile-site-key"
